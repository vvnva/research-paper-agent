APP_NAME=research-paper-agent
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8080
LOG_LEVEL=INFO

TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_WEBHOOK_SECRET=

LLM_API_BASE=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SEC=5.0
LLM_MAX_RETRIES=2
LLM_FALLBACK_MODEL=

ARXIV_API_BASE=https://export.arxiv.org/api/query
ARXIV_TIMEOUT_SEC=5.0
ARXIV_MAX_RETRIES=2

GLOBAL_TIMEOUT_SEC=15.0
QUERY_REWRITE_TIMEOUT_SEC=2.0
RANKING_TIMEOUT_SEC=3.0
SUMMARIZATION_TIMEOUT_SEC=5.0
MAX_CANDIDATES=15
TOP_N_RESULTS=5
MIN_QUERY_LEN=5
SESSION_TTL_SEC=3600
CACHE_TTL_SEC=3600
REDIS_URL=redis://redis:6379/0
REDIS_ENABLED=true

CB_WINDOW_SEC=60
CB_FAILURE_RATE_THRESHOLD=0.5
CB_MIN_REQUESTS=10
CB_OPEN_SEC=30
